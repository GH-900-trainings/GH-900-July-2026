# Copy this file to `.env` and fill in your own values.
# The `.env` file is git-ignored and must never be committed.

# Azure Maps subscription (primary) key used for the Weather, Search and
# Timezone services. Create an Azure Maps account to obtain one:
# https://learn.microsoft.com/azure/azure-maps/how-to-manage-account-keys
AZURE_MAPS_KEY=your-azure-maps-subscription-key

# Port the HTTP server listens on (optional, defaults to 3000).
PORT=3000
